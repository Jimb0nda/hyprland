{
    // Workspaces
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "persistent-workspaces": {
            "*": 5
        },
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X"
        }
    },

    // Cyberpunk separators
    "custom/sep1": {
        "format": "│",
        "tooltip": false
    },

    "custom/sep2": {
        "format": "│",
        "tooltip": false
    },

    "custom/sep3": {
        "format": "│",
        "tooltip": false
    },

    // Status indicator
    "custom/statusIndicator": {
        "format": "··· ─╱╲─ ···",
        "tooltip": false,
        "interval": 5,
        "exec": "echo '··· ─╱╲─ ···'"
    },

    // Power Menu
    "custom/menu": {
        "format": "󰍜",
        "tooltip-format": "Powermenu",
        "tooltip": false
    },

    "custom/logout": {
        "format": "󰗽",
        "tooltip-format": "Logout",
        "on-click": "killall -9 Hyprland",
        "tooltip": false
    },

    "custom/shutdown": {
        "format": "",
        "tooltip-format": "Shutdown",
        "on-click": "poweroff",
        "tooltip": false
    },

    "custom/restart": {
        "format": "",
        "tooltip-format": "Restart",
        "on-click": "reboot",
        "tooltip": false
    },

    "group/menu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": true
        },
        "modules": [
            "custom/menu",
            "custom/logout",
            "custom/shutdown",
            "custom/restart"
        ]
    },

    // Clock
    "clock": {
        "format": "{:%a, %d %b    %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
        "format-alt": "{:%d-%m-%Y}"
    },

    // Weather
    "custom/weather": {
        "format": "{}°",
        "tooltip": true,
        "interval": 3600,
        "exec": "wttrbar --location London",
        "return-type": "json"
    },

    "group/clockWeather": {
        "orientation": "horizontal",
        "modules": [
            "clock",
            "custom/weather"
        ]
    },

    // System
    "custom/archLogo": {
        "format": " 󰣇 ",
        "tooltip": false
    },

    // CPU
    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "kitty -e btop"
    },

    // Memory
    "memory": {
        "format": "/ M {}% ",
        "on-click": "kitty -e btop"
    },

    // Disk
    "disk": {
        "interval": 30,
        "format": "/ D {percentage_used}% ",
        "path": "/",
        "on-click": "kitty -e btop"
    },

    // Temperature
    "temperature": {
        "critical-threshold": 80,
        "format-critical": "{temperatureC}°C ",
        "format": "{temperatureC}°C "
    },

    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "   {signalStrength}%",
        "format-ethernet": "  {ipaddr}",
        "format-disconnected": "Not connected",
        "tooltip-format": " {ifname} via {gwaddri}",
        "tooltip-format-wifi": "   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "~/.config/assets/scripts/network-tui.sh"
    },

    // Battery
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": [" ", " ", " ", " ", " "]
    },

    // Pulseaudio
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "  {volume}%  {icon}",
        "format-bluetooth-muted": "  {icon}",
        "format-muted": "  {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "󰝟",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", " ", " "]
        },
        "on-click": "pavucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format": "",
        "format-disabled": "",
        "format-connected": "",
        "tooltip-format": "{device_alias}",
        "tooltip-format-connected": " {device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    // User
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false
    },

    // Idle Inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons": {
            "activated": "",
            "deactivated": ""
        },
        "on-click-right": "hyprlock"
    },

    // Backlight
    "backlight": {
        "format": "{percent}%  {icon}",
        "format-icons": ["", ""]
    }
}
