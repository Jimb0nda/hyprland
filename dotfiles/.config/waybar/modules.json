{
    // Workspaces
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "persistent-workspaces": {
            "*": 5
        },
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X"
        }
    },

    // Cyberpunk separators
    "custom/sep1": {
        "format": "Ôöé",
        "tooltip": false
    },

    "custom/sep2": {
        "format": "Ôöé",
        "tooltip": false
    },

    "custom/sep3": {
        "format": "Ôöé",
        "tooltip": false
    },

    // Status indicator
    "custom/statusIndicator": {
        "format": "┬À┬À┬À ÔöÇÔò▒Ôò▓ÔöÇ ┬À┬À┬À",
        "tooltip": false,
        "interval": 5,
        "exec": "echo '┬À┬À┬À ÔöÇÔò▒Ôò▓ÔöÇ ┬À┬À┬À'"
    },

    // Power Menu
    "custom/menu": {
        "format": "¾░ì£",
        "tooltip-format": "Powermenu",
        "tooltip": false
    },

    "custom/logout": {
        "format": "¾░ù¢",
        "tooltip-format": "Logout",
        "on-click": "killall -9 Hyprland",
        "tooltip": false
    },

    "custom/shutdown": {
        "format": "´Çæ",
        "tooltip-format": "Shutdown",
        "on-click": "poweroff",
        "tooltip": false
    },

    "custom/restart": {
        "format": "¯½Æ",
        "tooltip-format": "Restart",
        "on-click": "reboot",
        "tooltip": false
    },

    "group/menu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": true
        },
        "modules": [
            "custom/menu",
            "custom/logout",
            "custom/shutdown",
            "custom/restart"
        ]
    },

    // Clock
    "clock": {
        "format": "{:%a, %d %b    %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
        "format-alt": "{:%d-%m-%Y}"
    },

    // Weather
    "custom/weather": {
        "format": "{}┬░",
        "tooltip": true,
        "interval": 3600,
        "exec": "wttrbar --location London",
        "return-type": "json"
    },

    "group/clockWeather": {
        "orientation": "horizontal",
        "modules": [
            "clock",
            "custom/weather"
        ]
    },

    // System
    "custom/archLogo": {
        "format": " ¾░úç ",
        "tooltip": false
    },

    // CPU
    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "kitty -e btop"
    },

    // Memory
    "memory": {
        "format": "/ M {}% ",
        "on-click": "kitty -e btop"
    },

    // Disk
    "disk": {
        "interval": 30,
        "format": "/ D {percentage_used}% ",
        "path": "/",
        "on-click": "kitty -e btop"
    },

    // Temperature
    "temperature": {
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░C ´ïç",
        "format": "{temperatureC}┬░C ´ïï"
    },

    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "´ç½   {signalStrength}%",
        "format-ethernet": "´×û  {ipaddr}",
        "format-disconnected": "Not connected",
        "tooltip-format": "´×û {ifname} via {gwaddri}",
        "tooltip-format-wifi": "´ç½   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "´âü  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "kitty -e nmtui"
    },

    // Battery
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "´âº  {capacity}%",
        "format-plugged": "´âº  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "]
    },

    // Pulseaudio
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "´Ç¿  {volume}%  {icon}",
        "format-bluetooth-muted": "¯╗¿  {icon}",
        "format-muted": "¯╗¿  {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "¾░Øƒ",
        "format-icons": {
            "headphone": "´ÇÑ",
            "hands-free": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çª", "´Ç¿ ", "´Ç¿ "]
        },
        "on-click": "pavucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format": "´èö",
        "format-disabled": "´èö",
        "format-connected": "´èö",
        "tooltip-format": "{device_alias}",
        "tooltip-format-connected": "´èö {device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager"
    },

    // User
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false
    },

    // Idle Inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons": {
            "activated": "´Åü",
            "deactivated": "´Çú"
        },
        "on-click-right": "hyprlock"
    },

    // Backlight
    "backlight": {
        "format": "{percent}%  {icon}",
        "format-icons": ["´åà", "´äæ"]
    }
}
